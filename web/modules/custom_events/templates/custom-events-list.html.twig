<h1>Eventos</h1>

{% if events %}
  <div class="events-list">
    {% for event in events %}
      <div class="card" id="event-card-{{ event.id }}">
        <div class="header">
          <span class="header-titulo">Evento</span>
        </div>
        <div class="event-card">
          <span class="titulo">{{ event.title }}</span>
          <br>
          <span class="descrip">{{ event.description }}</span>
          <p><strong>País:</strong> {{ event.country }}</p>
          <p><strong>Fecha:</strong> {{ event.date }}</p>
          <p><strong>Inscritos:</strong> <span id="event-count-{{ event.id }}">{{ event.registrations_count }}</span></p>

          <div id="event-actions-{{ event.id }}">
            {% if logged_in %}
              {% if event.registered %}
                <span class="btn-registered">Ya estás inscrito</span>
              {% else %}
                {{ event.registration_form }}
              {% endif %}
            {% else %}
              <p><a href="/user/login">Inicia sesión para registrarte</a></p>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
{% else %}
  <p>No hay eventos disponibles.</p>
{% endif %}
